PROJECT_NAME           = "OpenNN"
PROJECT_BRIEF          = "Open-source neural networks library"
PROJECT_NUMBER         =
OUTPUT_DIRECTORY       = doxygen_build
CREATE_SUBDIRS         = NO

INPUT                  = opennn mainpage.md
INPUT_ENCODING         = UTF-8
FILE_PATTERNS          = *.h *.hpp *.hh *.md
RECURSIVE              = NO
EXCLUDE_PATTERNS       = */build/* */build_*/* */examples/* */tests/* */eigen/* */cudnn-frontend/* */googletest/* */packages/*

USE_MDFILE_AS_MAINPAGE = mainpage.md

EXTRACT_ALL            = YES
EXTRACT_PRIVATE        = NO
EXTRACT_STATIC         = YES
EXTRACT_LOCAL_CLASSES  = NO
HIDE_UNDOC_MEMBERS     = NO
HIDE_UNDOC_CLASSES     = NO
INLINE_INHERITED_MEMB  = NO

GENERATE_HTML          = YES
HTML_OUTPUT            = reference
HTML_FILE_EXTENSION    = .html
GENERATE_TREEVIEW      = YES
DISABLE_INDEX          = NO
SEARCHENGINE           = YES

GENERATE_LATEX         = NO
GENERATE_XML           = NO
GENERATE_RTF           = NO
GENERATE_MAN           = NO

HAVE_DOT               = YES
DOT_IMAGE_FORMAT       = svg
INTERACTIVE_SVG        = YES
CLASS_GRAPH            = YES
COLLABORATION_GRAPH    = NO
GROUP_GRAPHS           = YES
INCLUDE_GRAPH          = NO
INCLUDED_BY_GRAPH      = NO
CALL_GRAPH             = NO
CALLER_GRAPH           = NO
GRAPHICAL_HIERARCHY    = YES
DIRECTORY_GRAPH        = NO

QUIET                  = YES
WARNINGS               = YES
WARN_IF_UNDOCUMENTED   = NO
WARN_LOGFILE           = doxygen_build/doxygen_warnings.log

ALPHABETICAL_INDEX     = YES
SHOW_NAMESPACES        = YES
SHOW_FILES             = YES
SOURCE_BROWSER         = NO

PREDEFINED             = OPENNN_CUDA OPENNN_TESTS

GENERATE_AUTOGEN_DEF   = NO
SHOW_USED_FILES        = NO
